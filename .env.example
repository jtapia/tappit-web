# Stripe Payment Link. Create at https://dashboard.stripe.com/payment-links
# Set to the full https://buy.stripe.com/... URL
NEXT_PUBLIC_STRIPE_PAYMENT_LINK=

# Direct download URL for the notarized DMG. Must be PUBLICLY reachable — the
# source repo (jtapia/TappitX) is private, so host the DMG in the public
# jtapia/TappitX-releases repo (or Cloudflare R2).
# e.g. https://github.com/jtapia/TappitX-releases/releases/download/v1.0.0/TappitX-1.0.0.dmg
NEXT_PUBLIC_DOWNLOAD_URL=

# The purchase URL is configured via the Cloudflare Worker (worker/index.ts)
# that reads PURCHASE_URL from wrangler.toml [vars]. Deploy with `wrangler deploy`.
